# Copy this to .env for local testing (not committed to GitHub).
# On Railway, set these under your service's Variables tab instead.

SECRET_KEY=change-me-to-something-random

# Financial Cents (requires the Scale Plan for API access)
# Get this from Financial Cents Settings -> API / Integrations
FINANCIAL_CENTS_API_KEY=

# PandaDoc
# Get this from PandaDoc Settings -> API & Integrations -> API Keys
PANDADOC_API_KEY=
# Create a template for each document in PandaDoc's template editor,
# then paste each template's ID here (found in the template's URL/settings).
PANDADOC_ENGAGEMENT_LETTER_TEMPLATE_ID=
PANDADOC_RECORDS_RELEASE_TEMPLATE_ID=
